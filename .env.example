# ========================================================================
# Atlas Solver - Environment Variables Template
# Copy to .env and fill in real values
# ========================================================================

# --- Gemini API Keys ---
GEMINI_API_KEYS_FREE_POOL=""
GEMINI_API_KEY_FREE_OPS=
GEMINI_API_KEY2_FREE_OPS2=
GEMINI_API_KEY_FREE_FALLBACK=
GEMINI_API_KEY_FREE_FALLBACK2=
GEMINI_API_KEY=
GOOGLE_API_KEY=

PURIFIER_MODEL=gemini-3.1-pro-preview

# --- Active Account ---
ATLAS_LOGIN_EMAIL=
ATLAS_EMAIL=
GMAIL_USER=
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# --- Multi-Account (numbered) ---
GMAIL_IMAP_SERVER=imap.gmail.com

# USER1
ATLAS_LOGIN_EMAIL1=
ATLAS_EMAIL1=
GMAIL_USER1=
GMAIL_EMAIL1=
GMAIL_APP_PASSWORD1=

# --- Gemini Browser Accounts ---
GEMINI_ACCOUNTS=

HEARTBEAT_INTERVAL_SEC=600

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
COMMAND_CHANNEL_ID=
DISCORD_EMAIL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHATS=

# --- Server ---
SERVER_IPV4=
